{
  "manifest_version": 3,
  "name": "VeritasAI — Misinformation Detector",
  "version": "1.0.0",
  "description": "Analyze any webpage for fake news and misinformation with AI.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
